---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileHeader from '../components/ProfileHeader.astro';
import AlertCard from '../components/AlertCard.astro';
import BECCard from '../components/BECCard.astro';
import GettingStarted from '../components/GettingStarted.astro';
import StatsStrip from '../components/StatsStrip.astro';
import portfolio from '../data/portfolio.json';

// Strip any trailing slash so we can always write `${base}/path` safely.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Show the getting-started screen when the profile name is still a placeholder.
const isTemplate = !portfolio.profile.name || portfolio.profile.name.startsWith('[');
const pageTitle = isTemplate
  ? 'SOCSIM Member Portfolio'
  : `${portfolio.profile.name} — SOCSIM Portfolio`;

// Use ?? [] throughout so members who haven't updated their portfolio.json
// yet (after a template upgrade adding new investigation types) get a graceful
// empty section instead of a build error.
const data = portfolio as Record<string, any>;
// Newest first. Dates are ISO (yyyy-mm-dd) so string comparison sorts
// correctly; blank dates sink to the bottom.
const byDateDesc = (key: string) => (a: Record<string, any>, b: Record<string, any>) =>
  String(b[key] ?? '').localeCompare(String(a[key] ?? ''));

const alerts = ([...(data.alerts ?? [])] as Record<string, any>[]).sort(byDateDesc('date'));
const bec    = ([...(data.bec    ?? [])] as Record<string, any>[]).sort(
  (a, b) => String(b.investigationDate || b.incidentDateFrom || '')
    .localeCompare(String(a.investigationDate || a.incidentDateFrom || ''))
);

// Only link to a detail page when the case has an ID (a blank ID means
// no detail route was generated). Encode so odd characters can't break the URL.
const detailUrl = (section: string, id: string | undefined) => {
  const clean = String(id ?? '').trim();
  return clean ? `${base}/${section}/${encodeURIComponent(clean)}/` : undefined;
};
---
<BaseLayout title={pageTitle}>

  {isTemplate ? (
    <GettingStarted editorUrl={`${base}/editor.html`} />
  ) : (
    <>
      <ProfileHeader profile={portfolio.profile} />

      <StatsStrip alerts={alerts} bec={bec} />

      <!-- Alert Investigations -->
      <div class="section-label">Alert Investigations</div>

      {alerts.length === 0 ? (
        <div class="empty-state">No alert investigations yet.</div>
      ) : (
        alerts.map((a) => (
          <AlertCard
            alert={a}
            compact={true}
            detailUrl={detailUrl('alerts', a.id)}
          />
        ))
      )}

      <!-- BEC Case Drops -->
      <div class="section-label" style="margin-top:48px;">BEC Case Drops</div>

      {bec.length === 0 ? (
        <div class="empty-state">No BEC cases yet.</div>
      ) : (
        bec.map((b) => (
          <BECCard
            bec={b}
            compact={true}
            detailUrl={detailUrl('bec', b.id)}
          />
        ))
      )}
    </>
  )}

</BaseLayout>
