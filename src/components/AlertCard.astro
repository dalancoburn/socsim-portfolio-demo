---
import VerifiedBadge from './VerifiedBadge.astro';
import { md } from '../utils/md';

interface Alert {
  id: string;
  alertName: string;
  alertId?: string;
  date: string;
  severity: string;
  hostOrAccount: string;
  dateTime: string;
  whatTriggered: string;
  whyTriggered: string;
  whatHappened: string;
  evidence: string;
  wasSuccessful: string;
  verdict: string;
  verdictJustification: string;
  investigationSteps: string[];
  queries: string;
  categorisation: string;
  escalation: string;
  containment: string;
  alertTuning: string;
  lessonsLearned: string;
  tools: string[];
  customSections?: { title: string; content: string }[];
  verified: boolean;
}

interface Props {
  alert: Alert;
  detailUrl?: string;
  compact?: boolean;
}

const { alert, detailUrl } = Astro.props;

const severityClass: Record<string, string> = {
  Critical: 'severity-critical',
  High:     'severity-high',
  Medium:   'severity-medium',
  Low:      'severity-low',
};

const verdictClass: Record<string, string> = {
  'Malicious':      'verdict-malicious',
  'Non-malicious':  'verdict-nonmalicious',
  'Suspicious':     'verdict-suspicious',
};

const catClass: Record<string, string> = {
  TP:  'cat-tp',
  BTP: 'cat-btp',
  FP:  'cat-fp',
};

const catLabel: Record<string, string> = {
  TP:  'True Positive',
  BTP: 'Benign TP',
  FP:  'False Positive',
};

const compact = Astro.props.compact ?? !!detailUrl;

// Empty or malformed dates must never render as "Invalid Date"
function fmtDate(iso: string | undefined): string {
  if (!iso?.trim()) return '';
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso; // show the raw text rather than nothing
  return d.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' });
}
const dateLabel = fmtDate(alert.date);

// Tolerate hand-edited portfolio.json where arrays were removed
const steps = alert.investigationSteps ?? [];
const tools = alert.tools ?? [];
const customSections = (alert.customSections ?? []).filter((s) => s?.title || s?.content);
---

<article class:list={['case-card', compact && 'card-compact']}>

  <div class="case-header">
    <div style="flex:1;min-width:0;">

      <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:10px;">
        <span class="case-id">{alert.id}</span>
        <span class={`severity-badge ${severityClass[alert.severity] ?? 'severity-high'}`}>{alert.severity}</span>
        <span class={`verdict-badge ${verdictClass[alert.verdict] ?? ''}`}>{alert.verdict}</span>
        <span class={`cat-badge ${catClass[alert.categorisation] ?? ''}`}>{catLabel[alert.categorisation] ?? alert.categorisation}</span>
      </div>

      <h2 class="case-title" style="font-size:1.5rem;">
        {detailUrl
          ? <a href={detailUrl} style="color:inherit;text-decoration:none;">{alert.alertName}</a>
          : alert.alertName
        }
      </h2>

      <div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:16px;">
        {dateLabel && (
          <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:var(--text-dimmer);">
            {dateLabel}
          </span>
        )}
        {alert.hostOrAccount && (
          <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:var(--text-dimmer);">
            {alert.hostOrAccount}
          </span>
        )}
      </div>

      {compact && (
        <div class="case-summary md-content" style="margin-top:10px;" set:html={md(alert.whatHappened)} />
      )}

      {compact && detailUrl && (
        <a href={detailUrl} class="view-link">View full investigation →</a>
      )}

    </div>
    {alert.verified && <VerifiedBadge />}
  </div>

  {!compact && (
    <>
      <!-- Alert Summary -->
      <div class="case-section">
        <div class="case-section-label">Alert Summary</div>
        <div class="meta-row" style="margin-bottom:14px;">
          <div class="meta-item">
            <span class="meta-key">Host / Account</span>
            <span class="meta-val">{alert.hostOrAccount}</span>
          </div>
          <div class="meta-item">
            <span class="meta-key">Date & Time</span>
            <span class="meta-val">{alert.dateTime}</span>
          </div>
          {alert.alertId && (
            <div class="meta-item">
              <span class="meta-key">Alert ID</span>
              <span class="meta-val">{alert.alertId}</span>
            </div>
          )}
        </div>
        <div class="alert-box" style="margin-bottom:10px;">
          <span class="alert-rule">What triggered it: </span>{alert.whatTriggered}
        </div>
        <div class="alert-box md-content">
          <span class="alert-rule">Why it triggered: </span><span set:html={md(alert.whyTriggered)} style="display:inline;" />
        </div>
      </div>

      <!-- Investigation Findings -->
      <div class="case-section">
        <div class="case-section-label">What Happened</div>
        <div class="case-section-content md-content" set:html={md(alert.whatHappened)} />

        {alert.evidence && (
          <>
            <div class="case-section-label" style="margin-top:16px;">Evidence</div>
            <div class="case-section-content md-content" set:html={md(alert.evidence)} />
          </>
        )}

        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:16px;align-items:center;">
          <span class="meta-key">Was the activity successful?</span>
          <span class="meta-val">{alert.wasSuccessful}</span>
        </div>
      </div>

      <!-- Verdict -->
      <div class="case-section">
        <div class="case-section-label">Verdict</div>
        <div style="display:flex;gap:10px;align-items:flex-start;flex-wrap:wrap;">
          <div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;">
              <span class={`verdict-badge ${verdictClass[alert.verdict] ?? ''}`}>{alert.verdict}</span>
              <span class={`cat-badge ${catClass[alert.categorisation] ?? ''}`}>{catLabel[alert.categorisation] ?? alert.categorisation}</span>
            </div>
            <div class="case-section-content md-content" set:html={md(alert.verdictJustification)} />
          </div>
        </div>
      </div>

      <!-- Investigation Steps -->
      {steps.length > 0 && (
        <div class="case-section">
          <div class="case-section-label">Investigation Steps</div>
          <ol class="steps-list">
            {steps.map((step, i) => (
              <li class="step-item">
                <span class="step-num">{i + 1}</span>
                <span class="step-text">{step}</span>
              </li>
            ))}
          </ol>
        </div>
      )}

      <!-- KQL Queries -->
      {alert.queries && (
        <div class="case-section">
          <div class="case-section-label">Queries Used</div>
          <pre class="kql-block">{alert.queries}</pre>
        </div>
      )}

      <!-- Escalation & Containment -->
      <div class="case-section">
        <div class="case-section-label">Recommended Actions</div>
        <div class="meta-row" style="margin-bottom:14px;">
          <div class="meta-item">
            <span class="meta-key">Escalation</span>
            <span class="meta-val">{alert.escalation}</span>
          </div>
          <div class="meta-item">
            <span class="meta-key">Alert Tuning</span>
            <span class="meta-val">{alert.alertTuning}</span>
          </div>
        </div>
        {alert.containment && (
          <div class="case-section-content md-content" set:html={md(alert.containment)} />
        )}
      </div>

      <!-- Lessons Learned -->
      {alert.lessonsLearned && (
        <div class="case-section">
          <div class="case-section-label">Lessons Learned</div>
          <div class="case-section-content md-content" set:html={md(alert.lessonsLearned)} />
        </div>
      )}

      <!-- Member-defined custom sections -->
      {customSections.map((s) => (
        <div class="case-section">
          {s.title && <div class="case-section-label">{s.title}</div>}
          <div class="case-section-content md-content" set:html={md(s.content)} />
        </div>
      ))}

      <!-- Tools -->
      {tools.length > 0 && (
        <div class="case-section">
          <div class="case-section-label">Tools Used</div>
          <div class="tools-list">
            {tools.map((t) => <span class="tool-tag">{t}</span>)}
          </div>
        </div>
      )}
    </>
  )}

</article>
