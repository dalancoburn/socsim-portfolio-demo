---
import VerifiedBadge from './VerifiedBadge.astro';
import { md } from '../utils/md';

interface TimelineEntry {
  time: string;
  activity: string;
  detail?: string;
}

interface BECCase {
  id: string;
  caseName: string;
  caseReference: string;
  affectedAccount: string;
  incidentDateFrom: string;
  incidentDateTo: string;
  investigationDate: string;
  attackNarrative: string;
  timeline: TimelineEntry[];
  initialAccess: string;
  unauthorisedActivity: string;
  dataAccess: string;
  lessonsLearned: string;
  tools: string[];
  pdfUrl?: string;
  verified: boolean;
}

interface Props {
  bec: BECCase;
  detailUrl?: string;
}

const { bec, detailUrl } = Astro.props;
const compact = !!detailUrl;

function fmtDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<article class:list={['case-card', compact && 'card-compact']}>

  <div class="case-header">
    <div style="flex:1;min-width:0;">
      <div class="case-id">{bec.id} · {bec.caseReference}</div>
      <h2 class="case-title" style="font-size:1.5rem;">
        {detailUrl
          ? <a href={detailUrl} style="color:inherit;text-decoration:none;">{bec.caseName}</a>
          : bec.caseName
        }
      </h2>
      <div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:16px;">
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:var(--text-dimmer);">
          Affected: {bec.affectedAccount}
        </span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:var(--text-dimmer);">
          {fmtDate(bec.incidentDateFrom)} – {fmtDate(bec.incidentDateTo)}
        </span>
      </div>

      {compact && (
        <div class="case-summary md-content" style="margin-top:10px;" set:html={md(bec.attackNarrative)} />
      )}

      {compact && detailUrl && (
        <div style="display:flex;gap:12px;align-items:center;margin-top:10px;flex-wrap:wrap;">
          <a href={detailUrl} class="view-link">View full case →</a>
          {bec.pdfUrl && (
            <a href={bec.pdfUrl} class="view-link" target="_blank" rel="noopener noreferrer">PDF report ↗</a>
          )}
        </div>
      )}
    </div>
    {bec.verified && <VerifiedBadge />}
  </div>

  {!compact && (
    <>
      <!-- Attack Narrative -->
      <div class="case-section">
        <div class="case-section-label">Attack Narrative</div>
        <div class="case-section-content md-content" set:html={md(bec.attackNarrative)} />
        {bec.pdfUrl && (
          <a href={bec.pdfUrl} class="view-link" style="margin-top:12px;" target="_blank" rel="noopener noreferrer">
            Full PDF report ↗
          </a>
        )}
      </div>

      <!-- Timeline -->
      {bec.timeline.length > 0 && (
        <div class="case-section">
          <div class="case-section-label">Timeline of Events</div>
          <div class="bec-timeline">
            {bec.timeline.map((entry) => (
              <div class="bec-timeline-item">
                <div class="timeline-time">{entry.time}</div>
                <div class="bec-tl-right">
                  <div class="bec-tl-activity">{entry.activity}</div>
                  {entry.detail && <div class="bec-tl-detail">{entry.detail}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Findings -->
      {bec.initialAccess && (
        <div class="case-section">
          <div class="case-section-label">3.1 — Initial Access</div>
          <div class="case-section-content md-content" set:html={md(bec.initialAccess)} />
        </div>
      )}

      {bec.unauthorisedActivity && (
        <div class="case-section">
          <div class="case-section-label">3.2 — Unauthorised Activity</div>
          <div class="case-section-content md-content" set:html={md(bec.unauthorisedActivity)} />
        </div>
      )}

      {bec.dataAccess && (
        <div class="case-section">
          <div class="case-section-label">3.3 — Data Access</div>
          <div class="case-section-content md-content" set:html={md(bec.dataAccess)} />
        </div>
      )}

      <!-- Lessons Learned -->
      {bec.lessonsLearned && (
        <div class="case-section">
          <div class="case-section-label">Lessons Learned</div>
          <div class="case-section-content md-content" set:html={md(bec.lessonsLearned)} />
        </div>
      )}

      <!-- Tools -->
      {bec.tools.length > 0 && (
        <div class="case-section">
          <div class="case-section-label">Tools Used</div>
          <div class="tools-list">
            {bec.tools.map((t) => <span class="tool-tag">{t}</span>)}
          </div>
        </div>
      )}
    </>
  )}

</article>
